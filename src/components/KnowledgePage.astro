---
import Icon from './Icon.astro';
import type { KnowledgeDomain } from '../data/knowledge';

interface Props {
  domain: KnowledgeDomain;
  contents?: Record<string, string>;
  backHref?: string;
  backLabel?: string;
}

const { domain, contents = {}, backHref = '/', backLabel = '返回首页' } = Astro.props;

const allItems = domain.groups.flatMap((g) => g.items);
const readyItems = allItems.filter((item) => (
  !item.draft ||
  !!contents[item.id] ||
  !!item.cover ||
  !!item.slides?.length
));
const stageItems = readyItems.length > 0 ? readyItems : allItems;
---

<div class="kn-page" style={`--kn-color: ${domain.color}; --kn-soft: ${domain.soft}`}>

  <section class="kn-hero">
    <div class="container">
      <a href={backHref} class="back-link">
        <Icon name="arrow-left" size={16} strokeWidth={2} /> {backLabel}
      </a>
      <div class="kn-hero-row">
        <div class="kn-icon">
          <Icon name={domain.icon} size={28} strokeWidth={1.5} />
        </div>
        <h1 class="kn-title">{domain.title}</h1>
        <span class="kn-sub">{domain.subtitle}</span>
      </div>
      <p class="kn-desc">{domain.description}</p>
    </div>
  </section>

  <section class="section kn-content-section">
    <div class="container">
      {stageItems.length > 0 ? (
        <div class="kn-stage">
          {/* 顶部：精选目录 */}
          <nav class="kn-tabs">
            {stageItems.map((item, idx) => (
              <button
                class={`kn-tab${idx === 0 ? ' active' : ''}`}
                type="button"
                data-item={item.id}
              >
                <span class="kn-tab-idx">{String(idx + 1).padStart(2, '0')}</span>
                <span class="kn-tab-title">{item.title}</span>
              </button>
            ))}
          </nav>

          {/* 主体：图文阅读卡 */}
          <div class="kn-reader" data-kn-detail>
            <div class="kn-panels">
              {stageItems.map((item, idx) => {
                const isFirst = idx === 0;
                const hasSlides = !!(item.cover || (item.slides && item.slides.length > 0));
                const allSlides = [
                  ...(item.cover ? [{ url: item.cover, alt: item.title + ' 封面' }] : []),
                  ...(item.slides || []),
                ];
                const hasMd = !!contents[item.id];

                return (
                  <article
                    class={`kn-panel${isFirst ? ' active' : ''}`}
                    data-panel
                    data-item={item.id}
                  >
                    {hasSlides || hasMd ? (
                      <div class={`kn-panel-grid${!hasSlides ? ' no-media' : ''}`}>
                        {hasSlides && (
                          <div class="kn-media">
                            <div class="kn-carousel" data-carousel>
                              <div class="kn-carousel-viewport">
                                <div class="kn-carousel-track" data-track>
                                  {allSlides.map((slide, i) => (
                                    <div class={`kn-slide${i === 0 ? ' active' : ''}`} data-slide={i}>
                                      <img src={slide.url} alt={slide.alt || item.title} loading="lazy" draggable="false" />
                                    </div>
                                  ))}
                                </div>
                                {allSlides.length > 1 && (
                                  <>
                                    <button class="kn-carousel-btn kn-carousel-prev" data-prev aria-label="上一张">
                                      <Icon name="chevron-left" size={20} strokeWidth={2} />
                                    </button>
                                    <button class="kn-carousel-btn kn-carousel-next" data-next aria-label="下一张">
                                      <Icon name="chevron-right" size={20} strokeWidth={2} />
                                    </button>
                                  </>
                                )}
                              </div>
                              {allSlides.length > 1 && (
                                <div class="kn-carousel-dots" data-dots>
                                  {allSlides.map((_, i) => (
                                    <button class={`kn-dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`第 ${i + 1} 张`} />
                                  ))}
                                </div>
                              )}
                              <div class="kn-carousel-counter">
                                <span data-current>1</span> / {allSlides.length}
                              </div>
                            </div>
                          </div>
                        )}
                        <div class="kn-copy">
                          {hasMd ? (
                            <div class="kn-md-card">
                              <span class="kn-info-badge">
                                {item.type === 'video' ? '视频' : '图文'} · {String(idx + 1).padStart(2, '0')} / {String(stageItems.length).padStart(2, '0')}
                              </span>
                              <div class="kn-prose" set:html={contents[item.id]} />
                            </div>
                          ) : (
                            <div class="kn-md-card">
                              <p class="kn-muted">内容正在整理中。</p>
                            </div>
                          )}
                        </div>
                      </div>
                    ) : (
                      <div class="kn-placeholder-card">
                        <div class="kn-ph-dot"></div>
                        <p class="kn-ph-text">制作中</p>
                      </div>
                    )}
                  </article>
                );
              })}
            </div>
          </div>
        </div>
      ) : (
        <div class="kn-empty">
          <Icon name="sparkles" size={24} strokeWidth={1.8} />
          <p>内容还在整理中，敬请期待。</p>
        </div>
      )}
    </div>
  </section>
</div>

<script>
  const tabs = document.querySelectorAll<HTMLElement>('.kn-tab[data-item]');
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const itemId = tab.dataset.item;
      if (!itemId) return;

      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');

      panels.forEach((p) => p.classList.toggle('active', p.dataset.item === itemId));

      tab.scrollIntoView({ block: 'nearest', inline: 'center' });
    });
  });

  function initCarousel(carousel: HTMLElement) {
    const slides = carousel.querySelectorAll<HTMLElement>('[data-slide]');
    const dots = carousel.querySelectorAll<HTMLElement>('[data-dot]');
    const prevBtn = carousel.querySelector<HTMLElement>('[data-prev]');
    const nextBtn = carousel.querySelector<HTMLElement>('[data-next]');
    const counter = carousel.querySelector<HTMLElement>('[data-current]');
    const total = slides.length;
    if (total === 0) return;
    let current = 0;

    function goTo(idx: number) {
      if (idx < 0) idx = total - 1;
      if (idx >= total) idx = 0;
      slides.forEach((s) => s.classList.remove('active'));
      dots.forEach((d) => d.classList.remove('active'));
      slides[idx]?.classList.add('active');
      dots[idx]?.classList.add('active');
      if (counter) counter.textContent = String(idx + 1);
      current = idx;
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot) => {
      dot.addEventListener('click', () => goTo(Number(dot.dataset.dot)));
    });

    carousel.setAttribute('tabindex', '0');
    carousel.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); goTo(current - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1); }
    });

    let startX = 0, startY = 0;
    const viewport = carousel.querySelector<HTMLElement>('.kn-carousel-viewport');
    if (viewport) {
      viewport.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
      }, { passive: true });
      viewport.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - startX;
        const dy = e.changedTouches[0].clientY - startY;
        if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
          dx < 0 ? goTo(current + 1) : goTo(current - 1);
        }
      }, { passive: true });
    }
  }

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(initCarousel);
</script>

<style>
  .kn-hero { padding: 24px 0 8px; }

  .kn-content-section { padding: 22px 0 64px; }

  .back-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.78rem; color: var(--text3); margin-bottom: 10px;
    text-decoration: none;
  }
  .back-link:hover { color: var(--kn-color); }

  .kn-hero-row {
    display: flex; align-items: center; gap: 12px; margin-bottom: 6px;
  }

  .kn-icon {
    width: 42px; height: 42px; border-radius: 12px;
    background: var(--kn-soft); color: var(--kn-color);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .kn-title { font-size: 1.28rem; font-weight: 800; letter-spacing: 0; }
  .kn-sub { color: var(--text3); font-size: 0.8rem; }
  .kn-desc {
    color: var(--text2); font-size: 0.8rem; line-height: 1.6;
    max-width: 560px;
  }

  /* ── 精品阅读舞台：目录 | 图文卡 ── */
  .kn-stage {
    max-width: 980px;
    margin: 0 auto;
  }

  .kn-tabs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(132px, 1fr));
    gap: 8px;
    margin-bottom: 16px;
  }

  .kn-tab {
    min-height: 58px;
    border-radius: 16px;
    border: none;
    background: rgba(255, 255, 255, 0.34);
    cursor: pointer;
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 12px 14px;
    transition: all 0.2s;
    text-align: left;
    width: 100%;
    box-shadow: inset 0 0 0 1px rgba(45, 42, 40, 0.03);
  }

  .kn-tab:focus { outline: none; }
  .kn-tab:focus-visible { box-shadow: 0 0 0 2px var(--kn-soft); }

  .kn-tab:hover { background: var(--kn-soft); }

  .kn-tab.active {
    background: var(--surface);
    box-shadow: 0 8px 24px rgba(60, 40, 30, 0.035);
  }

  .kn-tab-idx {
    font-size: 0.62rem;
    font-weight: 700;
    color: var(--text3);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    width: auto;
    padding-top: 1px;
    text-align: left;
  }

  .kn-tab.active .kn-tab-idx { color: var(--kn-color); }

  .kn-tab-title {
    font-size: 0.78rem;
    color: var(--text2);
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: normal;
  }

  .kn-tab.active .kn-tab-title {
    color: var(--kn-color);
    font-weight: 700;
  }

  .kn-tab:hover .kn-tab-title { color: var(--text); }

  /* ── 图文阅读主体 ── */
  .kn-reader {
    width: 100%;
    min-width: 0;
    margin: 0;
  }

  .kn-panels { position: relative; }

  .kn-panel {
    display: none;
    animation: knFadeIn 0.2s ease;
  }
  .kn-panel.active { display: block; }

  .kn-panel-grid {
    display: grid;
    grid-template-columns: minmax(280px, 330px) minmax(0, 1fr);
    gap: 18px;
    align-items: stretch;
  }

  .kn-panel-grid.no-media {
    grid-template-columns: minmax(0, 760px);
    justify-content: center;
  }

  .kn-media,
  .kn-copy {
    min-width: 0;
  }

  .kn-copy {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .kn-copy-head,
  .kn-md-card {
    background: rgba(255, 255, 255, 0.42);
    border-radius: 18px;
    box-shadow: inset 0 0 0 1px rgba(45, 42, 40, 0.025);
  }

  .kn-copy-head {
    padding: 16px 18px;
  }

  @keyframes knFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── 轮播 ── */
  .kn-carousel {
    position: relative;
    outline: none;
    user-select: none;
  }

  .kn-carousel-viewport {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.42);
    aspect-ratio: 3 / 4;
    box-shadow: inset 0 0 0 1px rgba(45, 42, 40, 0.025);
  }

  .kn-carousel-track { width: 100%; height: 100%; position: relative; }

  .kn-slide {
    position: absolute; inset: 0;
    opacity: 0; transition: opacity 0.3s ease;
    display: flex; align-items: center; justify-content: center;
  }
  .kn-slide.active { opacity: 1; z-index: 1; }

  .kn-slide img {
    width: 100%; height: 100%;
    object-fit: contain;
  }

  .kn-carousel-btn {
    position: absolute; top: 50%; transform: translateY(-50%);
    z-index: 2;
    width: 32px; height: 32px;
    border-radius: 50%; border: none;
    background: rgba(255, 255, 255, 0.88);
    color: var(--text);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
    opacity: 0;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.1);
  }
  .kn-carousel-viewport:hover .kn-carousel-btn { opacity: 1; }
  .kn-carousel-btn:hover { background: #fff; transform: translateY(-50%) scale(1.06); }
  .kn-carousel-prev { left: 8px; }
  .kn-carousel-next { right: 8px; }

  .kn-carousel-dots {
    display: flex; justify-content: center;
    gap: 5px; padding: 8px 0 2px;
  }

  .kn-dot {
    width: 6px; height: 6px;
    border-radius: 999px; border: none;
    background: var(--text3); opacity: 0.3;
    cursor: pointer; padding: 0;
    transition: all 0.2s;
  }
  .kn-dot.active { opacity: 1; background: var(--kn-color); width: 16px; }

  .kn-carousel-counter {
    position: absolute; top: 10px; right: 12px; z-index: 3;
    font-size: 0.65rem; color: #fff;
    background: rgba(0, 0, 0, 0.35);
    padding: 2px 7px; border-radius: 8px;
    backdrop-filter: blur(4px);
  }

  /* ── Markdown 卡片 ── */
  .kn-md-card {
    padding: 16px;
    overflow: visible;
  }

  .kn-panel-grid.no-media .kn-md-card {
    max-height: min(720px, calc(100vh - 220px));
    overflow: auto;
    padding: 20px 22px;
    scrollbar-width: thin;
    scrollbar-color: rgba(45, 42, 40, 0.18) transparent;
  }

  .kn-panel-grid.no-media .kn-md-card::-webkit-scrollbar {
    width: 8px;
  }

  .kn-panel-grid.no-media .kn-md-card::-webkit-scrollbar-thumb {
    background: rgba(45, 42, 40, 0.16);
    border-radius: 999px;
  }

  .kn-prose {
    font-size: 0.79rem; line-height: 1.62; color: var(--text);
    max-width: 100%; overflow-wrap: break-word;
  }
  .kn-prose :global(h1) { font-size: 1rem; font-weight: 800; margin: 0 0 8px; color: var(--text); }
  .kn-prose :global(h2) { font-size: 0.76rem; font-weight: 800; margin: 12px 0 5px; color: var(--kn-color); }
  .kn-prose :global(h2:first-of-type) { margin-top: 0; }
  .kn-prose :global(h3) { font-size: 0.82rem; font-weight: 700; margin: 14px 0 6px; color: var(--text); }
  .kn-prose :global(h4) { font-size: 0.78rem; font-weight: 700; margin: 12px 0 4px; color: var(--text); }
  .kn-prose :global(p) { margin: 0 0 7px; color: var(--text2); }
  .kn-prose :global(ul), .kn-prose :global(ol) {
    display: grid;
    gap: 5px;
    margin: 0 0 8px;
    padding: 0;
    list-style: none;
  }
  .kn-prose :global(li) {
    margin: 0;
    padding: 6px 8px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.48);
    color: var(--text2);
  }
  .kn-prose :global(strong) { font-weight: 700; color: var(--text); }
  .kn-prose :global(a) { color: var(--kn-color); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 0.2s; }
  .kn-prose :global(a:hover) { border-bottom-color: var(--kn-color); }
  .kn-prose :global(code) { font-size: 0.76rem; background: var(--bg); padding: 2px 5px; border-radius: 4px; color: var(--kn-color); font-family: 'SF Mono', 'Fira Code', monospace; }
  .kn-prose :global(pre) { margin: 0 0 14px; padding: 12px 14px; background: #2d2a28; border-radius: 10px; overflow-x: auto; font-size: 0.74rem; line-height: 1.7; }
  .kn-prose :global(pre code) { background: none; padding: 0; color: #e8e0d8; font-size: inherit; }
  .kn-prose :global(blockquote) { margin: 0 0 12px; padding: 8px 14px; border-left: 3px solid var(--kn-color); background: var(--kn-soft); border-radius: 0 8px 8px 0; font-size: 0.8rem; color: var(--text2); }
  .kn-prose :global(blockquote p) { margin: 0; }
  .kn-prose :global(hr) { border: none; height: 1px; background: rgba(0, 0, 0, 0.05); margin: 20px 0; }
  .kn-prose :global(table) { width: 100%; border-collapse: collapse; margin: 0 0 14px; font-size: 0.76rem; }
  .kn-prose :global(th) { text-align: left; padding: 6px 8px; background: var(--bg); font-weight: 700; border-bottom: 1px solid rgba(0, 0, 0, 0.06); }
  .kn-prose :global(td) { padding: 5px 8px; border-bottom: 1px solid rgba(0, 0, 0, 0.03); color: var(--text2); }

  @media (min-width: 769px) {
    .kn-prose :global(ul), .kn-prose :global(ol) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* ── 占位卡片 ── */
  .kn-placeholder-card {
    border-radius: 16px;
    background: var(--surface2);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    aspect-ratio: 3 / 4;
    border: 1.5px dashed rgba(0, 0, 0, 0.1);
  }

  .kn-ph-dot {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: var(--kn-soft);
  }

  .kn-ph-text {
    font-size: 0.78rem;
    color: var(--text3);
  }

  .kn-info-badge {
    display: inline-block;
    font-size: 0.65rem;
    color: var(--kn-color);
    background: var(--kn-soft);
    padding: 3px 10px;
    border-radius: 8px;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .kn-info-desc {
    font-size: 0.82rem;
    color: var(--text2);
    line-height: 1.65;
  }

  .kn-muted {
    margin: 0;
    font-size: 0.8rem;
    color: var(--text3);
    line-height: 1.7;
  }

  .kn-empty {
    min-height: 180px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 10px; border-radius: var(--radius-lg);
    background: var(--surface2); color: var(--text3);
    text-align: center; padding: 24px;
  }
  .kn-empty p { font-size: 0.85rem; line-height: 1.7; max-width: 360px; }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .kn-hero { padding: 20px 0 4px; }
    .kn-content-section { padding: 18px 0 36px; }
    .kn-hero-row { flex-wrap: wrap; gap: 8px; }
    .kn-title { font-size: 1.1rem; }
    .kn-sub { font-size: 0.72rem; }
    .kn-desc { font-size: 0.75rem; }

    .kn-stage {
      max-width: 100%;
    }

    .kn-tabs {
      display: flex;
      flex-direction: row;
      position: static;
      overflow-x: auto;
      gap: 6px;
      margin: 0 -18px;
      padding: 2px 18px 8px;
      width: auto;
      justify-content: flex-start;
      -webkit-overflow-scrolling: touch;
      scroll-padding: 16px;
    }
    .kn-tabs::-webkit-scrollbar { display: none; }

    .kn-tab {
      padding: 8px 14px;
      white-space: nowrap;
      flex-shrink: 0;
      border-radius: 20px;
      background: var(--surface2);
      width: auto;
      max-width: 72vw;
      min-height: auto;
    }
    .kn-tab.active {
      background: var(--kn-soft);
    }
    .kn-tab-idx { display: none; }
    .kn-tab-title { font-size: 0.76rem; }

    .kn-reader {
      width: 100%;
      max-width: 100%;
      margin: 0;
    }

    .kn-panel-grid,
    .kn-panel-grid.no-media {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .kn-carousel-viewport {
      aspect-ratio: 3 / 4;
      width: 100%;
    }

    .kn-copy {
      gap: 10px;
    }

    .kn-copy-head {
      padding: 14px;
    }

    .kn-carousel-btn { opacity: 0.8; }

    .kn-md-card {
      padding: 16px 14px;
      max-height: none;
    }

    .kn-panel-grid.no-media .kn-md-card {
      max-height: min(72vh, 620px);
      overflow: auto;
      padding: 16px 14px;
    }
  }
</style>
