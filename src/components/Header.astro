---
import Icon from './Icon.astro';

const hubNav = [
  { label: '计算机', href: '/cs', color: 'var(--pink)' },
  { label: '金融', href: '/finance', color: 'var(--gold)' },
  { label: '身体', href: '/body', color: 'var(--green)' },
  { label: '摄影', href: '/photo', color: 'var(--cyan)' },
  { label: '美食', href: '/food', color: 'var(--orange)' },
];

const currentPath = Astro.url.pathname;
const activeHub = hubNav.find(h => currentPath.startsWith(h.href));
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="brand">
      <span class="brand-text">安静</span>
    </a>

    <nav class="nav" id="nav">
      {hubNav.map((item) => (
        <a href={item.href} class:list={['nav-link', { active: currentPath.startsWith(item.href) }]}>
          <span class="nav-dot" style={`background:${item.color};`}></span>
          {item.label}
        </a>
      ))}
    </nav>

    <button class="menu-toggle" id="menuToggle" aria-label="菜单">
      <Icon name="menu" size={20} strokeWidth={1.5} />
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(253, 245, 243, 0.85);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--border);
    height: 56px;
  }

  .header-inner {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex; align-items: center;
    text-decoration: none; color: var(--text);
    font-weight: 700; font-size: 1rem;
    letter-spacing: 0;
  }

  .nav { display: flex; align-items: center; gap: 2px; }

  .nav-link {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: var(--radius-sm);
    color: var(--text3); font-size: 0.84rem; font-weight: 500;
    text-decoration: none; transition: all var(--transition);
  }

  .nav-link:hover { color: var(--text); background: var(--surface); }
  .nav-link.active { color: var(--text); background: var(--surface); }

  .nav-dot {
    width: 6px; height: 6px; border-radius: 50%;
    opacity: 0.6; transition: opacity var(--transition);
  }

  .nav-link:hover .nav-dot,
  .nav-link.active .nav-dot { opacity: 1; }

  .menu-toggle {
    display: none; background: none; border: none;
    cursor: pointer; padding: 8px; color: var(--text3);
  }

  @media (max-width: 768px) {
    .header-inner { padding: 0 18px; }
    .menu-toggle { display: flex; align-items: center; }
    .nav {
      display: none; position: absolute; top: 56px; left: 0; right: 0;
      flex-direction: column; background: rgba(253, 245, 243, 0.96);
      backdrop-filter: blur(24px); border-bottom: 1px solid var(--border);
      padding: 10px 18px 14px; gap: 4px;
    }
    .nav.open { display: flex; }
    .nav-link { width: 100%; padding: 10px 16px; }
  }
</style>

<script>
  const toggle = document.getElementById('menuToggle');
  const nav = document.getElementById('nav');
  toggle?.addEventListener('click', () => nav?.classList.toggle('open'));
</script>
