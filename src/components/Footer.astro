---
const xiaohongshuId = '8973452455';
const wechatId = '18668247774';
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">

      <!-- 左：品牌信息 -->
      <div class="footer-left">
        <div class="footer-brand">安静</div>
        <p class="footer-desc">大模型yes工程师 / 这么一砸反而活了操盘手</p>
        <div class="footer-social">
          <div class="social-contact social-xhs">
            <button class="social-link social-link--brand" type="button" title="小红书" aria-label="小红书" aria-haspopup="dialog">
              <img src="/assets/social/xiaohongshu-icon.png" alt="" width="22" height="22" loading="lazy" />
            </button>
            <div class="contact-popup" role="dialog" aria-label="小红书">
              <button
                class="contact-id-card"
                type="button"
                data-copy-contact
                data-copy-value={xiaohongshuId}
                data-copy-success="已复制小红书号"
                aria-label={`复制小红书号 ${xiaohongshuId}`}
              >
                <strong>{xiaohongshuId}</strong>
              </button>
              <div class="contact-copy-toast" data-copy-toast aria-live="polite"></div>
              <img
                class="contact-qr"
                src="/assets/social/xiaohongshu-qr.png"
                alt="小红书二维码"
                width="166"
                height="166"
                loading="lazy"
              />
            </div>
          </div>

          <a href="https://www.douyin.com" target="_blank" rel="noopener" class="social-link social-link--brand" title="抖音" aria-label="抖音">
            <img src="/assets/social/douyin-icon.png" alt="" width="22" height="22" loading="lazy" />
          </a>

          <div class="social-contact social-wechat">
            <button class="social-link social-link--brand" type="button" title="微信" aria-label="微信" aria-haspopup="dialog">
              <img src="/assets/social/wechat-icon.svg" alt="" width="22" height="22" loading="lazy" />
            </button>
            <div class="contact-popup" role="dialog" aria-label="微信">
              <button
                class="contact-id-card"
                type="button"
                data-copy-contact
                data-copy-value={wechatId}
                data-copy-success="已复制微信号"
                aria-label={`复制微信号 ${wechatId}`}
              >
                <strong>{wechatId}</strong>
              </button>
              <div class="contact-copy-toast" data-copy-toast aria-live="polite"></div>
              <img
                class="contact-qr"
                src="/assets/social/wechat-qr.png"
                alt="微信二维码"
                width="166"
                height="166"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- 右：引流区域 -->
      <div class="footer-right">
        <a href="https://aigc.anjing.cc" target="_blank" rel="noopener" class="promo-card">
          <div class="promo-inner">
            <div class="promo-front">anjing aigc</div>
            <div class="promo-back">输入即创作，无需学设计</div>
          </div>
        </a>
        <a href="https://richfree.anjing.cc" target="_blank" rel="noopener" class="promo-card">
          <div class="promo-inner">
            <div class="promo-front">anjing richfree</div>
            <div class="promo-back">请和我一起财富自由 谢谢</div>
          </div>
        </a>
        <a href="https://music.anjing.cc" target="_blank" rel="noopener" class="promo-card">
          <div class="promo-inner">
            <div class="promo-front">anjing music</div>
            <div class="promo-back">属于你安静的音乐世界</div>
          </div>
        </a>
      </div>

    </div>

    <div class="footer-bottom">
      <span>&copy; {new Date().getFullYear()} 安静</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg);
    padding: 32px 0 0;
  }

  .footer-inner { width: 100%; max-width: var(--max-width); margin: 0 auto; padding: 0 24px; }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(240px, 0.8fr) minmax(0, 1.8fr);
    align-items: stretch;
    gap: 32px;
  }

  .footer-left { min-width: 0; }
  .footer-brand { font-size: 1.15rem; font-weight: 700; margin-bottom: 10px; }
  .footer-desc {
    color: var(--text2);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 16px;
    transition: opacity var(--transition);
  }
  .footer-social { display: flex; gap: 8px; align-items: center; }

  .footer-right {
    min-width: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .promo-card {
    min-width: 0;
    min-height: 96px;
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .promo-card[href],
  .promo-card[href] * {
    cursor: var(--cursor-pointer);
  }

  .promo-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(60, 40, 30, 0.06);
  }

  .promo-inner {
    display: grid;
    border-radius: var(--radius-lg);
    overflow: hidden;
    height: 100%;
  }

  .promo-front,
  .promo-back {
    grid-area: 1 / 1;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.55;
    padding: 14px 16px;
    white-space: nowrap;
    transition: opacity 0.28s ease, transform 0.28s ease;
  }

  .promo-front {
    border: 1px solid rgba(45, 42, 40, 0.08);
    color: var(--text3);
    background: rgba(255, 255, 255, 0.22);
    opacity: 1;
    transform: scale(1);
    z-index: 2;
  }

  .promo-back {
    color: var(--text2);
    background: var(--surface2);
    opacity: 0;
    transform: translateY(4px) scale(0.99);
    z-index: 1;
  }

  .promo-card:hover .promo-front {
    opacity: 0;
    transform: translateY(-4px) scale(0.99);
  }

  .promo-card:hover .promo-back {
    opacity: 1;
    transform: scale(1);
  }

  @media (hover: none) {
    .promo-card:hover .promo-front {
      opacity: 1;
      transform: none;
    }

    .promo-card:hover .promo-back {
      opacity: 0;
      transform: translateY(4px) scale(0.99);
    }
  }

  .social-link {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: var(--radius-sm);
    background: var(--surface2); color: var(--text3); transition: all var(--transition);
    cursor: var(--cursor-pointer);
    text-decoration: none;
  }

  button.social-link {
    border: 0;
    padding: 0;
    font: inherit;
  }

  .social-link:hover { background: var(--pink-soft); color: var(--pink); }

  .social-link--brand img {
    width: 22px;
    height: 22px;
    border-radius: 7px;
    display: block;
  }

  .social-contact {
    position: relative;
    --contact-color: #ff2442;
    --contact-soft: rgba(255, 36, 66, 0.1);
    --contact-border: rgba(255, 36, 66, 0.34);
    --contact-id-border: rgba(255, 36, 66, 0.22);
    --contact-bg-start: rgba(255, 247, 249, 0.98);
    --contact-bg-end: rgba(255, 255, 255, 0.98);
    --contact-shadow: rgba(255, 36, 66, 0.12);
  }

  .social-wechat {
    --contact-color: #1aad19;
    --contact-soft: rgba(26, 173, 25, 0.1);
    --contact-border: rgba(26, 173, 25, 0.28);
    --contact-id-border: rgba(26, 173, 25, 0.18);
    --contact-bg-start: rgba(246, 255, 248, 0.98);
    --contact-bg-end: rgba(255, 255, 255, 0.98);
    --contact-shadow: rgba(26, 173, 25, 0.12);
  }

  .social-contact:hover .social-link,
  .social-contact:focus-within .social-link {
    background: var(--contact-soft);
    color: var(--contact-color);
  }

  .footer-left:has(.social-contact:hover) .footer-desc,
  .footer-left:has(.social-contact:focus-within) .footer-desc {
    opacity: 0;
  }

  .contact-popup {
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    width: 184px;
    padding: 8px;
    border: 1px solid var(--contact-border);
    border-radius: 16px;
    background: linear-gradient(180deg, var(--contact-bg-start), var(--contact-bg-end));
    box-shadow: 0 18px 48px var(--contact-shadow), 0 10px 32px rgba(45, 42, 40, 0.08);
    transform: translateX(-50%) translateY(4px);
    opacity: 0;
    visibility: hidden;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 100;
  }

  .social-contact:hover .contact-popup,
  .social-contact:focus-within .contact-popup {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .footer-social:has(.social-contact:hover) .social-contact:not(:hover) .contact-popup {
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(4px);
  }

  .contact-popup::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-top: 7px solid var(--contact-bg-end);
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
  }

  .contact-id-card {
    width: 100%;
    border: 1px solid var(--contact-id-border);
    border-radius: 12px;
    padding: 8px 10px;
    background: rgba(255, 255, 255, 0.82);
    color: var(--text);
    cursor: var(--cursor-pointer);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    transition: border-color var(--transition), background var(--transition), transform var(--transition);
  }

  .contact-id-card:hover,
  .contact-id-card:focus-visible {
    border-color: var(--contact-border);
    background: #fff;
    transform: translateY(-1px);
    outline: none;
  }

  .contact-id-card strong {
    font-size: 0.94rem;
    letter-spacing: 0;
    white-space: nowrap;
  }

  .contact-id-card.is-copied {
    border-color: var(--contact-border);
  }

  .contact-copy-toast {
    position: absolute;
    top: 0;
    left: 50%;
    z-index: 1;
    padding: 6px 10px;
    border-radius: 999px;
    background: var(--contact-color);
    color: #fff;
    box-shadow: 0 10px 24px var(--contact-shadow);
    font-size: 0.72rem;
    line-height: 1;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translate(-50%, -8px) scale(0.96);
    transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
  }

  .contact-copy-toast.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -30px) scale(1);
  }

  .contact-qr {
    display: block;
    width: 100%;
    height: auto;
    margin-top: 8px;
    border-radius: 11px;
    background: #fff;
    box-shadow: inset 0 0 0 1px rgba(45, 42, 40, 0.04);
  }

  .footer-heading {
    font-size: 0.8rem; font-weight: 600; color: var(--text);
    text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px;
  }

  .footer-link {
    display: block; color: var(--text2); font-size: 0.82rem;
    padding: 3px 0; text-decoration: none; transition: color var(--transition);
  }
  .footer-link:hover { color: var(--accent); }

  .footer-bottom {
    margin-top: 32px; padding: 16px 0;
    border-top: 1px solid var(--border);
    text-align: center; color: var(--text3); font-size: 0.8rem;
  }

  @media (max-width: 768px) {
    .footer { padding: 28px 0 0; }
    .footer-inner { padding: 0 18px; }
    .footer-grid { grid-template-columns: 1fr; gap: 20px; }
    .footer-left { text-align: center; }
    .footer-brand { font-size: 1rem; }
    .footer-desc { font-size: 0.78rem; }
    .footer-social { justify-content: center; }
    .footer-right {
      max-width: 100%;
      gap: 10px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .promo-card {
      min-width: 0;
      min-height: 76px;
    }
    .promo-front,
    .promo-back {
      font-size: 0.76rem;
      padding: 16px 12px;
      min-height: 72px;
    }
    .footer-bottom {
      margin-top: 20px;
      padding: 12px 0;
      font-size: 0.72rem;
    }
  }

  @media (max-width: 360px) {
    .footer-right {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const copyWithFallback = (value) => {
    const textarea = document.createElement('textarea');
    textarea.value = value;
    textarea.setAttribute('readonly', '');
    textarea.style.position = 'fixed';
    textarea.style.top = '-9999px';
    document.body.appendChild(textarea);
    textarea.select();
    const copied = document.execCommand('copy');
    textarea.remove();
    return copied;
  };

  document.querySelectorAll('[data-copy-contact]').forEach((button) => {
    button.addEventListener('click', async () => {
      const value = button.getAttribute('data-copy-value') || '';
      const successText = button.getAttribute('data-copy-success') || '已复制';
      const toast = button.parentElement?.querySelector('[data-copy-toast]');
      let copied = false;

      try {
        if (navigator.clipboard) {
          await navigator.clipboard.writeText(value);
          copied = true;
        }
      } catch {
        copied = false;
      }

      if (!copied) copied = copyWithFallback(value);

      if (toast) {
        toast.textContent = copied ? successText : '复制失败';
        toast.classList.add('is-visible');
      }
      button.classList.toggle('is-copied', copied);

      const previousTimer = button.getAttribute('data-copy-timer');
      if (previousTimer) window.clearTimeout(Number(previousTimer));

      const nextTimer = window.setTimeout(() => {
        if (toast) toast.classList.remove('is-visible');
        button.classList.remove('is-copied');
        button.removeAttribute('data-copy-timer');
      }, 1500);

      button.setAttribute('data-copy-timer', String(nextTimer));
    });
  });
</script>
