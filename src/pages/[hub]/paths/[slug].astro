---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PathTimeline from '../../../components/PathTimeline.astro';
import { paths } from '../../../data/paths';
import { projects } from '../../../data/projects';

const { hub, slug } = Astro.params;
export function getStaticPaths() {
  return paths
    .filter((path) => !!path.hub)
    .map((path) => ({
      params: { hub: path.hub, slug: path.id },
    }));
}

const path = paths.find((p) => p.hub === hub && p.id === slug);

const colorToTheme = (color: string): 'accent' | 'green' | 'orange' | 'purple' => {
  if (color.includes('green')) return 'green';
  if (color.includes('orange')) return 'orange';
  if (color.includes('purple')) return 'purple';
  if (color.includes('cyan')) return 'accent';
  if (color.includes('pink')) return 'accent';
  return 'accent';
};

const theme = path ? colorToTheme(path.color) : 'accent';
---

<BaseLayout title={path ? `${path.title} — 安静` : '未找到页面 — 安静'} hub={hub}>
  {path ? (
    <PathTimeline path={path} projects={projects} theme={theme} backHref={`/${hub}`} backLabel="返回赛道首页" />
  ) : (
    <div class="container" style="padding: 48px 0;">
      <p>这个路径还没有配置。</p>
    </div>
  )}
</BaseLayout>
