---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HubHome from '../../components/HubHome.astro';
import { paths } from '../../data/paths';
import { domains } from '../../data/knowledge';
import {
  financeTrioCards,
  financePathCards,
  financeKnowledgeCards,
} from '../../data/finance-home';

const hub = Astro.params.hub;
export function getStaticPaths() {
  return [
    { params: { hub: 'cs' } },
    { params: { hub: 'finance' } },
  ];
}

const csTrioCards = [
  {
    title: '我是谁',
    color: 'var(--accent)',
    items: [
      { dot: 'var(--accent)', label: '一线全栈工程师', desc: '计算机基础 + 工程实践 + AI 应用落地' },
      { dot: 'var(--cyan)', label: '4 个真实项目', desc: '电商客服、知识库 RAG、AIGC、工作流' },
      { dot: 'var(--pink)', label: '生产级交付', desc: '真实系统，不是 Demo' },
    ],
  },
  {
    title: '能给你什么',
    color: 'var(--purple)',
    items: [
      { dot: 'var(--accent)', label: '计算机基础', desc: '操作系统、网络、数据结构与算法' },
      { dot: 'var(--purple)', label: '工程实践', desc: '架构设计、最佳实践、性能优化' },
      { dot: 'var(--orange)', label: 'AI 应用', desc: 'LLM、RAG、Agent、前沿探索' },
    ],
  },
  {
    title: '我们的交付',
    color: 'var(--green)',
    items: [
      { dot: 'var(--accent)', label: '完整项目代码', desc: '企业级标准，不是玩具' },
      { dot: 'var(--green)', label: '配套文档', desc: '背景、设计、选型与思考' },
      { dot: 'var(--orange)', label: '答疑讲解', desc: '不懂就问，帮你搞明白' },
    ],
  },
];

const csPathCards = paths
  .filter((p) => p.hub === 'cs')
  .map((p) => ({
    title: p.title,
    hook: p.subtitle,
    color: p.color,
    href: `/cs/paths/${p.id}`,
    items: p.audience,
  }));

const csKnowledgeHooks: Record<string, string> = {
  'cs-fundamentals': '基础决定上限',
  engineering: '工程决定质量',
  'ai-and-llm': '趋势决定方向',
  frontier: '视野决定未来',
};

const csKnowledgeCards = domains
  .filter((d) => d.hub === 'cs')
  .map((d) => ({
    title: d.title,
    hook: csKnowledgeHooks[d.id] ?? d.subtitle,
    color: d.color,
    href: `/cs/knowledge/${d.id}`,
    items: d.groups.flatMap((group) => group.items.slice(0, 1).map((item) => item.title)).slice(0, 3),
  }));

const hubs: Record<string, {
  title: string;
  subtitle: string;
  introNote?: string;
  trioCards: typeof csTrioCards | typeof financeTrioCards;
  pathCards: typeof csPathCards | typeof financePathCards;
  knowledgeCards: typeof csKnowledgeCards | typeof financeKnowledgeCards;
  pathLead: string;
}> = {
  cs: {
    title: '安静 · 计算机',
    subtitle: '基础 · 工程 · AI',
    trioCards: csTrioCards,
    pathCards: csPathCards,
    knowledgeCards: csKnowledgeCards,
    pathLead: '选一个最像你的画像，我帮你规划一条路',
  },
  finance: {
    title: '安静 · 金融 Hub',
    subtitle: '交易、研究与长期配置',
    trioCards: financeTrioCards,
    pathCards: financePathCards,
    knowledgeCards: financeKnowledgeCards,
    pathLead: '把金融赛道拆成不同交易画像，从短线到长线逐步展开',
  },
};

const hubData = hubs[hub];
---

<BaseLayout title={hubData ? `${hubData.title} — 安静` : '未找到页面 — 安静'} hub={hub}>
  {hubData ? (
    <HubHome
      title={hubData.title}
      subtitle={hubData.subtitle}
      introNote={hubData.introNote}
      trioCards={hubData.trioCards}
      pathCards={hubData.pathCards}
      knowledgeCards={hubData.knowledgeCards}
      pathLead={hubData.pathLead}
      backHref="/"
      backLabel="返回总入口"
    />
  ) : (
    <div class="container" style="padding: 48px 0;">
      <p>这个 hub 暂时还没有配置。</p>
    </div>
  )}
</BaseLayout>
