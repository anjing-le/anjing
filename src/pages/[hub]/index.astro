---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HubHome from '../../components/HubHome.astro';
import { paths } from '../../data/paths';
import { domains } from '../../data/knowledge';
import {
  financeTrioCards,
  financePathCards,
  financeKnowledgeCards,
} from '../../data/finance-home';

const hub = Astro.params.hub;
export function getStaticPaths() {
  return [
    { params: { hub: 'ai' } },
    { params: { hub: 'finance' } },
  ];
}


const aiTrioCards = [
  {
    title: '我是谁',
    color: 'var(--accent)',
    items: [
      { dot: 'var(--accent)', label: '一线全栈&大模型应用工程师', desc: '专注 AI 应用落地与工程最佳实践' },
      { dot: 'var(--cyan)', label: '4 个真实 AI 项目', desc: '电商客服、知识库 RAG、AIGC、工作流' },
      { dot: 'var(--pink)', label: '生产级交付', desc: '真实系统，不是 Demo' },
    ],
  },
  {
    title: '能给你什么',
    color: 'var(--purple)',
    items: [
      { dot: 'var(--accent)', label: '传统工程', desc: '架构设计、最佳实践、性能优化' },
      { dot: 'var(--purple)', label: 'LLM 应用', desc: 'LLM 基础、LLM 应用、Agent 架构设计' },
      { dot: 'var(--orange)', label: 'LLM 前沿探索', desc: 'Agentic、OpenClaw' },
    ],
  },
  {
    title: '我们的交付',
    color: 'var(--green)',
    items: [
      { dot: 'var(--accent)', label: '完整项目代码', desc: '企业级标准，不是玩具' },
      { dot: 'var(--green)', label: '配套文档', desc: '背景、设计、选型与思考' },
      { dot: 'var(--orange)', label: '答疑讲解', desc: '不懂就问，帮你搞明白' },
    ],
  },
];

const aiPathCards = paths
  .filter((p) => p.hub === 'ai-lab')
  .map((p) => ({
    title: p.title,
    hook: p.subtitle,
    color: p.color,
    href: `/ai/paths/${p.id}`,
    items: p.audience,
  }));

const aiKnowledgeHooks: Record<string, string> = {
  engineering: '基础决定上限',
  'llm-basics': '理解决定精度',
  'llm-apps': '落地决定价值',
  frontier: '眼界决定方向',
};

const aiKnowledgeCards = domains
  .filter((d) => d.hub === 'ai-lab')
  .map((d) => ({
    title: d.title,
    hook: aiKnowledgeHooks[d.id] ?? d.subtitle,
    color: d.color,
    href: `/ai/knowledge/${d.id}`,
    items: d.groups.flatMap((group) => group.items.slice(0, 1).map((item) => item.title)).slice(0, 3),
  }));

const hubs: Record<string, {
  title: string;
  subtitle: string;
  introNote: string;
  trioCards: typeof aiTrioCards | typeof financeTrioCards;
  pathCards: typeof aiPathCards | typeof financePathCards;
  knowledgeCards: typeof aiKnowledgeCards | typeof financeKnowledgeCards;
  pathLead: string;
}> = {
  ai: {
    title: '安静 · AI Hub',
    subtitle: '大模型培训与应用实战',
    introNote: '这一页保留你现在这套 AI 首页和子页的完整风格，后面只负责持续补内容。',
    trioCards: aiTrioCards,
    pathCards: aiPathCards,
    knowledgeCards: aiKnowledgeCards,
    pathLead: '选一个最像你的画像，我帮你规划一条路',
  },
  finance: {
    title: '安静 · 金融 Hub',
    subtitle: '交易、研究与长期配置',
    introNote: '金融赛道会和 AI 赛道保持同样的结构与视觉，只是内容换成金融方向。',
    trioCards: financeTrioCards,
    pathCards: financePathCards,
    knowledgeCards: financeKnowledgeCards,
    pathLead: '把金融赛道拆成不同交易画像，从短线到长线逐步展开',
  },
};

const hubData = hubs[hub];
---

<BaseLayout title={hubData ? `${hubData.title} — 安静` : '未找到页面 — 安静'}>
  {hubData ? (
    <HubHome
      title={hubData.title}
      subtitle={hubData.subtitle}
      introNote={hubData.introNote}
      trioCards={hubData.trioCards}
      pathCards={hubData.pathCards}
      knowledgeCards={hubData.knowledgeCards}
      pathLead={hubData.pathLead}
    />
  ) : (
    <div class="container" style="padding: 48px 0;">
      <p>这个 hub 暂时还没有配置。</p>
    </div>
  )}
</BaseLayout>
