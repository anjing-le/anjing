---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import KnowledgePage from '../../../components/KnowledgePage.astro';
import { domains } from '../../../data/knowledge';

const { hub, slug } = Astro.params;
export function getStaticPaths() {
  return domains
    .filter((domain) => domain.hub === 'cs' || domain.hub === 'finance')
    .map((domain) => ({
      params: { hub: domain.hub, slug: domain.id },
    }));
}

const domain = domains.find((d) => d.hub === hub && d.id === slug);
---

<BaseLayout title={domain ? `${domain.title} — 安静` : '未找到页面 — 安静'} hub={hub}>
  {domain ? (
    <KnowledgePage domain={domain} backHref={`/${hub}`} backLabel="返回赛道首页" />
  ) : (
    <div class="container" style="padding: 48px 0;">
      <p>这个知识域还没有配置。</p>
    </div>
  )}
</BaseLayout>
