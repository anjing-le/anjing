---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KnowledgePage from '../../components/KnowledgePage.astro';
import { domains } from '../../data/knowledge';

const domain = domains.find((d) => d.id === 'llm-apps')!;
---

<BaseLayout title={`${domain.title} — 安静 · AI Lab`}>
