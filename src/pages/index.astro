---
import BaseLayout from '../layouts/BaseLayout.astro';
import { hubs } from '../data/hubs';
import '../styles/index.css';
---

<BaseLayout title="你好，我是安静" hideHeader>
  <div class="index-page">
    <section class="intro-screen" aria-labelledby="intro-title">
      <div class="container intro-container">
        <img
          class="intro-character"
          src="/assets/ip/anjing-character.png"
          alt="安静的手绘 IP 形象"
          loading="eager"
          decoding="async"
        />
        <h1 id="intro-title" class="entry-title">我是<span class="entry-name">安静</span></h1>
      </div>
    </section>

    <section class="tracks-screen" id="tracks" aria-label="赛道目录">
      <div class="container">
        <div class="entry-grid">
          {hubs.map((hub) => (
            <a href={hub.href} class={`flip-container flip-link${hub.href === '#' ? ' is-disabled' : ''}`}>
              <div class="flip-inner">
                <div class="flip-front">
                  <h3 class="flip-front-title" style={`color:${hub.color};`}>{hub.title}</h3>
                </div>
                <div class="flip-back">
                  <h3 class="flip-back-title" style={`color:${hub.color};`}>{hub.subtitle}</h3>
                  <p class="entry-desc">{hub.description}</p>
                  <ul class="entry-list">
                    {hub.items.map((item) => (
                      <li><span class="idx-card-dot" style={`background:${hub.color};`}></span><span>{item}</span></li>
                    ))}
                  </ul>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
