---
import BaseLayout from '../layouts/BaseLayout.astro';
import { hubs } from '../data/hubs';
import '../styles/index.css';
---

<BaseLayout title="你好，我是安静 — 多赛道入口">
  <div class="container">
    <div class="entry-hero">
      <h1 class="entry-title">你好，我是安静</h1>
      <p class="entry-subtitle">这里是我的多赛道入口，先从 AI Hub 和金融 Hub 开始，后续还会继续扩展。</p>
    </div>

    <div class="entry-grid">
      {hubs.map((hub) => (
        <a href={hub.href} class={`flip-container flip-link${hub.href === '#' ? ' is-disabled' : ''}`}>
          <div class="flip-inner">
            <div class="flip-front">
              <h2 class="flip-front-title" style={`color:${hub.color};`}>{hub.title}</h2>
            </div>
            <div class="flip-back">
              <h2 class="flip-back-title" style={`color:${hub.color};`}>{hub.subtitle}</h2>
              <p class="entry-desc">{hub.description}</p>
              <ul class="entry-list">
                {hub.items.map((item) => (
                  <li><span class="idx-card-dot" style={`background:${hub.color};`}></span><span>{item}</span></li>
                ))}
              </ul>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="entry-foot">
      <span>当前已接入：AI Hub、金融 Hub</span>
      <span>后续可继续按同样结构扩展更多赛道</span>
    </div>
  </div>
</BaseLayout>
