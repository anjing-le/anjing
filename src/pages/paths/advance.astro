---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PathTimeline from '../../components/PathTimeline.astro';
import { paths } from '../../data/paths';
import { projects } from '../../data/projects';

const path = paths.find((p) => p.id === 'advance')!;
---

<BaseLayout title={`${path.title} — 安静 · 计算机`} hub="cs">
  <PathTimeline path={path} projects={projects} theme="purple" backHref="/cs" backLabel="返回计算机" />
</BaseLayout>
